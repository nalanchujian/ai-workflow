{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "allOf": [
    { "$ref": "../node-artifact.schema.json" },
    {
      "required": [
        "path",
        "reason"
      ],
      "properties": {
        "node": { "const": "requirement-routing" },
        "path": { "type": ["string", "null"], "pattern": "^[a-z][a-z0-9_]*$" },
        "reason": { "type": "string", "minLength": 1 },
        "evidence": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    {
      "if": {
        "required": ["template_version"],
        "properties": { "template_version": { "const": 2 } }
      },
      "then": { "required": ["evidence"] }
    }
  ]
}
