{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "allOf": [
    { "$ref": "../node-artifact.schema.json" },
    {
      "required": [
        "path",
        "reason"
      ],
      "properties": {
        "node": { "const": "requirement-routing" },
        "path": { "type": ["string", "null"], "pattern": "^[a-z][a-z0-9_]*$" },
        "reason": { "type": "string", "minLength": 1 },
        "evidence": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "unresolved_items": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "id",
              "type",
              "issue_and_impact",
              "owner",
              "retry_node",
              "completion_condition"
            ],
            "properties": {
              "id": { "type": "string", "minLength": 1 },
              "type": {
                "enum": ["risk", "defect", "material_dependency", "environment_blocker"]
              },
              "issue_and_impact": { "type": "string", "minLength": 1 },
              "owner": { "type": "string", "minLength": 1 },
              "retry_node": {
                "type": "string",
                "pattern": "^[a-z][a-z0-9]*(?:-[a-z0-9]+)*$"
              },
              "completion_condition": { "type": "string", "minLength": 1 }
            },
            "additionalProperties": false
          }
        }
      }
    },
    {
      "if": {
        "required": ["template_version"],
        "properties": { "template_version": { "const": 2 } }
      },
      "then": { "required": ["evidence"] }
    },
    {
      "if": {
        "required": ["artifact_schema_version"],
        "properties": { "artifact_schema_version": { "const": 1 } }
      },
      "then": { "required": ["evidence", "unresolved_items"] }
    },
    {
      "if": {
        "required": ["artifact_schema_version", "status"],
        "properties": {
          "artifact_schema_version": { "const": 1 },
          "status": { "const": "completed" }
        }
      },
      "then": {
        "properties": { "unresolved_items": { "maxItems": 0 } }
      }
    },
    {
      "if": {
        "required": ["artifact_schema_version", "status"],
        "properties": {
          "artifact_schema_version": { "const": 1 },
          "status": { "const": "blocked" }
        }
      },
      "then": {
        "properties": { "unresolved_items": { "minItems": 1 } }
      }
    }
  ]
}
