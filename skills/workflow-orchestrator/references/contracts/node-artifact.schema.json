{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "node-artifact.schema.json",
  "type": "object",
  "required": [
    "task_id",
    "node",
    "status",
    "attempt"
  ],
  "properties": {
    "task_id": { "type": "string", "minLength": 1 },
    "node": { "type": "string", "pattern": "^[a-z][a-z0-9]*(?:-[a-z0-9]+)*$" },
    "status": { "enum": ["awaiting_confirmation", "completed", "blocked"] },
    "attempt": { "type": "integer", "minimum": 1 },
    "artifact_schema_version": { "const": 1 },
    "template_version": { "enum": [2, 3] }
  },
  "allOf": [
    {
      "if": {
        "required": ["status"],
        "properties": { "status": { "const": "awaiting_confirmation" } }
      },
      "then": {
        "properties": { "node": { "const": "requirement-intake" } }
      }
    }
  ]
}
